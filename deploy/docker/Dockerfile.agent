# Agora Agent container — Python 3.12 slim
# Serves any Agora agent depending on CMD arg.
#
# v4.0 changes:
#   - Added mpmath, sympy, scipy (required by Galois/Euler numerics tools)
#   - Added numerics/ and olympiad/ package directories
#   - Added google-cloud-storage and google-cloud-firestore for A2A state + GCS artifact passing
#   - Non-root user security enforced

FROM python:3.12-slim AS base

# Security: run as non-root
RUN groupadd -r agora && useradd -r -g agora agora

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python dependencies (pinned for reproducibility)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Core scientific stack required by Galois/Euler (v3 regression prevention)
RUN pip install --no-cache-dir \
    mpmath==1.3.0 \
    sympy==1.12 \
    scipy==1.13.1 \
    numpy==1.26.4 \
    z3-solver>=4.12.0

# Cloud / A2A stack
RUN pip install --no-cache-dir \
    google-cloud-storage>=2.14.0 \
    google-cloud-firestore>=2.16.0 \
    functions-framework==3.* \
    fastapi>=0.111.0 \
    uvicorn[standard]>=0.30.0 \
    httpx>=0.27.0 \
    pydantic>=2.7.0 \
    structlog>=24.0.0

# Optionally install google-adk (non-fatal if not available in all envs)
RUN pip install --no-cache-dir "google-adk>=2.0.0" || true
RUN pip install --no-cache-dir "google-antigravity>=0.1.0" || true

# Application code
COPY agents/ agents/
COPY core/ core/

# Numerics tools — required by Galois numerics_evaluator and Euler tools
# (v3 regression: missing olympiad/ caused empty proofs → False VERIFIED)
COPY numerics/ numerics/
COPY olympiad/ olympiad/

# Solvers — required by Euler lean4 prover pipeline
COPY solvers/ solvers/

# Alexandrie — required for artifact management
COPY alexandrie/ alexandrie/

# Non-root execution
RUN mkdir -p /gcs && chown -R agora:agora /gcs
RUN chown -R agora:agora /app
USER agora

# Environment
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8080 \
    AGENT_NAME=socrates \
    BUDGET_LIMIT=100 \
    PROJECT_BUDGET=500 \
    OIDC_ENABLED=1 \
    FIRESTORE_ENABLED=1

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Default: run Socrates. Override via CMD in Cloud Run service definition.
ENTRYPOINT ["python", "-m"]
CMD ["agents.socrates.server"]
