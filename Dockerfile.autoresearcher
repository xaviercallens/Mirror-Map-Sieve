FROM python:3.10-slim

WORKDIR /app

# Install dependencies including sympy
RUN pip install requests google-cloud-storage sympy

# Copy the discovery package and the loop script
COPY discovery /app/discovery
COPY Alexandrie/solvers/autoresearch_loop.py /app/

ENV PYTHONUNBUFFERED=1

ENTRYPOINT ["python3", "autoresearch_loop.py"]
