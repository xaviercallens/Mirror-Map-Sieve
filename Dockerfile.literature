FROM python:3.12-slim
LABEL maintainer="Xavier Callens / Socrate AI Lab"
LABEL description="Agora Scientific Literature Review Pipeline"
WORKDIR /app
COPY . /app/
RUN mkdir -p /app/output/literature
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
EXPOSE 8080
CMD ["python", "agents/pipelines/literature_server.py"]
